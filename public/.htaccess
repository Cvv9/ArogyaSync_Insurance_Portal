# index.html must never be cached — always fetch fresh so new JS bundles are loaded
<FilesMatch "^index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# JS/CSS/fonts/images carry a content-hash in the filename — safe to cache forever
<FilesMatch "\.(js|css|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|ico|svg|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
